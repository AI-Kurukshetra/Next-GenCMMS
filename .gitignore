# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local secrets/config
*.key
*.crt
*.p12
*.pfx
.npmrc

# Supabase local/CLI state
.supabase/
supabase/.temp/
supabase/.branches/
supabase/config.toml
supabase/.env*

# vercel
.vercel

# local sqlite/db/cache
*.sqlite
*.sqlite3
*.db
*.db-journal

# editor/OS noise
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# typescript
*.tsbuildinfo
next-env.d.ts

# flutter mobile app
mobile/.dart_tool/
mobile/.flutter-plugins-dependencies
mobile/.pub/
mobile/build/
